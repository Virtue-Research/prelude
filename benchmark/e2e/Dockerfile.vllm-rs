# vllm.rs server — GPU inference
#
# Build (from vllm.rs source directory):
#   docker build -f /path/to/Dockerfile.vllm-rs -t vllm-rs-e2e /path/to/vllm.rs
#
# Run:
#   docker run --gpus all -p 8000:8000 \
#     -v ~/.cache/huggingface:/data \
#     vllm-rs-e2e --model Qwen/Qwen3-0.6B --port 8000

ARG CUDA_VERSION=12.8.0
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends --allow-change-held-packages \
    libnccl-dev libnccl2 \
    curl git ca-certificates \
    libssl-dev pkg-config \
    clang libclang-dev \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir maturin patchelf cffi

# Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

ARG CUDA_COMPUTE_CAP=80
ENV CUDA_COMPUTE_CAP="${CUDA_COMPUTE_CAP}"

WORKDIR /vllm.rs
COPY . .

# Build with GPU features
RUN ./build.sh --release --features "cuda,nccl,graph,python,flash-attn,flash-context" \
    && cargo build --release --features "cuda,nccl,graph,flash-attn,flash-context" \
    && pip3 install --no-cache-dir target/wheels/* \
    && install -Dm755 target/release/vllm-rs /usr/local/bin/vllm-rs \
    && printf '%s\n' '#!/bin/sh' 'exec python3 -m vllm_rs.server "$@"' > /usr/local/bin/vllm-rs-server \
    && chmod +x /usr/local/bin/vllm-rs-server \
    && cargo clean

# Fix nccl symlink
RUN arch="$(uname -m)" \
    && libdir="/usr/lib/${arch}-linux-gnu" \
    && if [ ! -e "${libdir}/libnccl.so" ] && [ -e "${libdir}/libnccl.so.2" ]; then \
         ln -s libnccl.so.2 "${libdir}/libnccl.so"; \
       fi

ENV HUGGINGFACE_HUB_CACHE=/data
EXPOSE 8000

ENTRYPOINT ["vllm-rs-server"]
CMD ["--host", "0.0.0.0", "--port", "8000"]
