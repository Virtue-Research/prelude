# llama.cpp + vllm.rs — both in one image, GPU and CPU
#
# Build:
#   docker build -f benchmark/genai-bench/Dockerfile.others -t prelude-others benchmark/genai-bench
#
# Run llama.cpp (GPU):
#   docker run --gpus all -p 8000:8000 -v /path/to/models:/models prelude-others \
#     llama-server -m /models/model.gguf --host 0.0.0.0 --port 8000 -ngl 99
#
# Run llama.cpp (CPU):
#   docker run -p 8000:8000 -v /path/to/models:/models prelude-others \
#     llama-server -m /models/model.gguf --host 0.0.0.0 --port 8000 -ngl 0
#
# Run vllm.rs (GPU):
#   docker run --gpus all -p 8000:8000 -v ~/.cache/huggingface:/data prelude-others \
#     vllm-rs-server --model Qwen/Qwen3-0.6B --host 0.0.0.0 --port 8000

FROM nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# ── System deps (union of llama.cpp + vllm.rs) ───────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends --allow-change-held-packages \
    build-essential cmake ninja-build \
    libnccl-dev libnccl2 \
    curl git ca-certificates \
    libssl-dev pkg-config \
    clang libclang-dev \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Python build tools (for vllm.rs maturin wheel)
RUN pip3 install --no-cache-dir maturin patchelf cffi

# CUDA env
ENV CUDA_HOME=/usr/local/cuda
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}

# ── llama.cpp ─────────────────────────────────────────────────────────────
# CUDA driver stub for build-time linking
RUN ln -s /usr/local/cuda/lib64/stubs/libcuda.so /usr/lib/x86_64-linux-gnu/libcuda.so.1

RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
    && cd /opt/llama.cpp \
    && pip3 install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu \
    && pip3 install --no-cache-dir -e gguf-py transformers sentencepiece \
    && cmake -B build -DCMAKE_BUILD_TYPE=Release \
        -DGGML_CUDA=ON -DGGML_AVX512=ON \
    && cmake --build build -j$(nproc) --target llama-server \
    && ln -s /opt/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server

# Remove build-time stub (real driver from nvidia-docker at runtime)
RUN rm -f /usr/lib/x86_64-linux-gnu/libcuda.so.1

# ── vllm.rs ───────────────────────────────────────────────────────────────
ARG CUDA_COMPUTE_CAP=80
ENV CUDA_COMPUTE_CAP="${CUDA_COMPUTE_CAP}"

RUN git clone --depth 1 https://github.com/yuzhounie/vllm.rs /tmp/vllm.rs \
    && cd /tmp/vllm.rs \
    && cargo build --release --bin vllm-rs --features "cuda,nccl,flashinfer,graph,cutlass" \
    && install -Dm755 target/release/vllm-rs /usr/local/bin/vllm-rs \
    && rm -rf /tmp/vllm.rs \
    || echo "WARNING: vllm.rs build failed — skipping"

# Fix nccl symlink
RUN arch="$(uname -m)" \
    && libdir="/usr/lib/${arch}-linux-gnu" \
    && if [ ! -e "${libdir}/libnccl.so" ] && [ -e "${libdir}/libnccl.so.2" ]; then \
         ln -s libnccl.so.2 "${libdir}/libnccl.so"; \
       fi

ENV HUGGINGFACE_HUB_CACHE=/data
EXPOSE 8000
CMD ["bash"]
